# ──────────────────────────────────────────────────────────────────────────────
# Angel One SmartAPI credentials (required)
# Obtain from https://smartapi.angelone.in/
# ──────────────────────────────────────────────────────────────────────────────
ANGEL_API_KEY=your_api_key_here
ANGEL_CLIENT_ID=your_client_id_here
ANGEL_PASSWORD=your_password_here
ANGEL_TOTP_SECRET=your_totp_secret_here

# ──────────────────────────────────────────────────────────────────────────────
# Database
# Default: async SQLite via aiosqlite
# For PostgreSQL: postgresql+asyncpg://user:pass@localhost:5432/trading
# ──────────────────────────────────────────────────────────────────────────────
DB_URL=sqlite+aiosqlite:///./trading.db

# ──────────────────────────────────────────────────────────────────────────────
# Telegram notifications (optional)
# Create a bot via @BotFather and get the chat ID from @userinfobot
# ──────────────────────────────────────────────────────────────────────────────
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
# TELEGRAM_CHAT_ID=123456789

# ──────────────────────────────────────────────────────────────────────────────
# Email notifications (optional)
# ──────────────────────────────────────────────────────────────────────────────
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USER=your_email@gmail.com
# EMAIL_PASSWORD=your_app_password

# ──────────────────────────────────────────────────────────────────────────────
# Risk management
# ──────────────────────────────────────────────────────────────────────────────
MAX_LOSS_PER_DAY=5000
MAX_TRADES_PER_DAY=20
CAPITAL_PER_TRADE=50000
MAX_DRAWDOWN_PCT=5.0

# ──────────────────────────────────────────────────────────────────────────────
# Redis (optional – used for caching and pub/sub if available)
# ──────────────────────────────────────────────────────────────────────────────
# REDIS_URL=redis://localhost:6379/0

# ──────────────────────────────────────────────────────────────────────────────
# Logging
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
# ──────────────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
